{
  "name": "vortex-business",
  "version": "1.0.0",
  "description": "Sistema de gestão para micro empresas",
  "main": "main.js",
  "scripts": {
    "start": "GDK_BACKEND=x11 electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux deb"
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.vortexbusiness.app",
    "productName": "Vortex Business",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vortex Business",
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeaderIcon": "src/assets/icon.ico",
      "perMachine": false,
      "artifactName": "Vortex Business Setup.exe"
    },
    "linux": {
      "target": "deb",
      "category": "Office",
      "icon": "src/assets/icon.png"
    },
    "extraResources": [
      {
        "from": "backend-bin",
        "to": "backend-bin"
      }
    ]
  },
  "author": {
    "name": "Carlos Henrique de Melo",
    "email": "ch0892160@gmail.com"
  },
  "homepage": "https://github.com/CarlosHenriqueDeMelo/vortex-business"
}